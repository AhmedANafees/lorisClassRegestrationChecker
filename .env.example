# Copy this file to .env and fill in your real values.
# .env is gitignored -- never commit your actual credentials.

# The Gmail address you're sending FROM
EMAIL_SENDER=your_gmail_address@gmail.com

# A Gmail App Password (NOT your real Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be turned on for your Google account.)
# It's a 16-character code like: abcd efgh ijkl mnop
EMAIL_APP_PASSWORD=your_16_char_app_password

# Where notification emails get sent
EMAIL_RECIPIENT=recipient_address@example.com
